# ============================================================
# Fotoserver-Koffer – Konfigurationsvorlage
# Kopieren nach .env und anpassen. .env NIEMALS committen!
# ============================================================

# --- Backend ---
UPLOAD_DIR=./uploads
DATA_DIR=./data
MAX_FILE_SIZE_MB=100
DISK_MIN_FREE_GB=2
ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/quicktime

# Zufälligen Key generieren: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME

# --- Passwörter (als bcrypt-Hash speichern, Klartext NIEMALS hier eintragen) ---
# Hash generieren: python3 -c "import bcrypt; print(bcrypt.hashpw(b'deinPasswort', bcrypt.gensalt()).decode())"
USER_PASSWORD_HASH=CHANGE_ME
ADMIN_PASSWORD_HASH=CHANGE_ME

# --- Server ---
HOST=0.0.0.0
PORT=8000

# --- Hotspot (nur Raspberry Pi) – Echte Werte NUR in .env, nicht committen ---
HOTSPOT_SSID=FotoServer
HOTSPOT_PASSWORD=CHANGE_ME
HOTSPOT_INTERFACE=wlan0
HOTSPOT_IP=192.168.4.1

# --- Betriebsmodus ---
# 'manual' = Fotoserver nur über Skripte starten, kein Autostart beim Booten
FOTOSERVER_MODE=manual
